{
  "id": "claw-mem",
  "kind": "memory",
  "name": "Claw Memory System",
  "description": "Three-tier memory system for OpenClaw (Local-First)",
  "configSchema": {
    "type": "object",
    "properties": {
      "pythonPath": {
        "type": "string",
        "description": "Python executable path (default: python3)"
      },
      "bridgePath": {
        "type": "string",
        "description": "Bridge module path (default: -m claw_mem.bridge)"
      },
      "workspaceDir": {
        "type": "string",
        "description": "Workspace directory (default: OpenClaw workspace)"
      },
      "autoRecall": {
        "type": "boolean",
        "description": "Auto-inject memories before agent starts (default: true)"
      },
      "autoCapture": {
        "type": "boolean",
        "description": "Auto-store memories after agent ends (default: true)"
      },
      "topK": {
        "type": "number",
        "description": "Max memories to recall (default: 10)"
      },
      "attentionEngine": {
        "type": "object",
        "description": "Attention OS v2.0.0-rc.2 configuration",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable attention-based context filtering (default: true)"
          },
          "decayFactor": {
            "type": "number",
            "description": "Attention decay factor per cycle (default: 0.9)"
          },
          "maxNodesInContext": {
            "type": "number",
            "description": "Max high-attention nodes to include in context (default: 5)"
          },
          "causalDepth": {
            "type": "number",
            "description": "DAG traversal depth for causal chain (default: 1)"
          }
        }
      }
    },
    "additionalProperties": false
  },
  "activation": {
    "onStartup": true
  }
}